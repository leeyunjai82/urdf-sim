<?xml version="1.0"?>
<robot name="arm4">
  <material name="white"><color rgba="0.92 0.92 0.92 1"/></material>
  <material name="grey"><color rgba="0.55 0.55 0.58 1"/></material>

  <link name="base_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="base_link.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><mesh filename="base_link.stl"/></geometry>
    </collision>
  </link>
  <link name="shoulder">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="shoulder.stl"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="shoulder.stl"/></geometry>
    </collision>
  </link>
  <link name="link1">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="link1.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><mesh filename="link1.stl"/></geometry>
    </collision>
  </link>
  <link name="link2">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="link2.stl"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="link2.stl"/></geometry>
    </collision>
  </link>
  <link name="gripper_base">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="gripper_base.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><mesh filename="gripper_base.stl"/></geometry>
    </collision>
  </link>
  <link name="moving_jaw">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="moving_jaw.stl"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="moving_jaw.stl"/></geometry>
    </collision>
  </link>

  <!-- J1: 베이스 요 (바닥에서 45mm) -->
  <joint name="joint1_yaw" type="revolute">
    <parent link="base_link"/><child link="shoulder"/>
    <origin xyz="0 0 0.045"/><axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="2" velocity="2"/>
  </joint>

  <!-- J2: 어깨 피치 (요축에서 45mm), 축 X -->
  <joint name="joint2_shoulder" type="revolute">
    <parent link="shoulder"/><child link="link1"/>
    <origin xyz="0 0 0.045"/><axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2" velocity="2"/>
  </joint>

  <!-- J3: 팔꿈치 피치 (115mm) -->
  <joint name="joint3_elbow" type="revolute">
    <parent link="link1"/><child link="link2"/>
    <origin xyz="0 0 0.115"/><axis xyz="1 0 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="2" velocity="2"/>
  </joint>

  <!-- 그리퍼 마운트 (105mm, 고정) -->
  <joint name="joint4_mount" type="fixed">
    <parent link="link2"/><child link="gripper_base"/>
    <origin xyz="0 0 0.105"/>
  </joint>

  <!-- J4: 랙앤피니언 prismatic. 0도=45mm 개방, 180도=15mm (스트로크 30mm) -->
  <joint name="gripper_joint" type="prismatic">
    <parent link="gripper_base"/><child link="moving_jaw"/>
    <origin xyz="-0.047 0 0.010"/><axis xyz="1 0 0"/>
    <limit lower="0" upper="0.030" effort="5" velocity="0.1"/>
  </joint>
</robot>
